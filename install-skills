#!/usr/bin/env bash
# install-skills — copy plugin skills to ~/.claude/skills/
#
# Usage:
#   install-skills                              interactive: list available, ask which to install
#   install-skills skill1 skill2 ...            install specific skills by name
#   install-skills --all                        install all not-yet-installed plugin skills
#   install-skills --list                       list available (not installed) without installing
#   install-skills --from-match <github-url>    install skills recommended by skill-inventory match

set -euo pipefail

SKILLS_DIR="${HOME}/.claude/skills"
CACHE_DIR="${HOME}/.claude/plugins/cache"
SKILL_INDEX="${TMPDIR:-/tmp}/skill-index-$$.txt"

# ─── helpers ────────────────────────────────────────────────────────────────

bold()   { printf '\033[1m%s\033[0m' "$*"; }
green()  { printf '\033[32m%s\033[0m' "$*"; }
yellow() { printf '\033[33m%s\033[0m' "$*"; }
dim()    { printf '\033[2m%s\033[0m' "$*"; }

cleanup() { rm -f "${SKILL_INDEX}"; }
trap cleanup EXIT

# Build index file: "name:path_to_SKILL.md" (one per name, first match wins)
build_index() {
  find "${CACHE_DIR}" -name "SKILL.md" 2>/dev/null \
    | while read -r path; do
        name=$(basename "$(dirname "${path}")")
        echo "${name}:${path}"
      done \
    | sort -t: -k1,1 -u \
    > "${SKILL_INDEX}"
}

is_installed() { [[ -d "${SKILLS_DIR}/${1}" ]]; }

# Find path for a skill name in the index (returns empty string if not found)
find_in_index() {
  grep "^${1}:" "${SKILL_INDEX}" 2>/dev/null | cut -d: -f2- | head -1 || true
}

install_skill() {
  local name="$1" src_path="$2"
  local src_dir
  src_dir="$(dirname "${src_path}")"

  if is_installed "${name}"; then
    echo "  $(yellow '~') ${name} — already installed, skipping"
    return 0
  fi

  cp -r "${src_dir}" "${SKILLS_DIR}/${name}"
  echo "  $(green '✓') ${name}"
}

# ─── main ───────────────────────────────────────────────────────────────────

mode="${1:-interactive}"

build_index

case "${mode}" in

  --list)
    echo ""
    echo "$(bold 'Available plugin skills (not yet installed globally)')"
    echo ""
    count=0
    while IFS=: read -r name path; do
      if ! is_installed "${name}"; then
        plugin_dir=$(echo "${path}" | sed "s|${CACHE_DIR}/||" | cut -d/ -f1)
        printf "  %-35s $(dim '%s')\n" "${name}" "${plugin_dir}"
        count=$((count + 1))
      fi
    done < "${SKILL_INDEX}"
    echo ""
    echo "$(dim "${count} skill(s) available")"
    echo ""
    ;;

  --all)
    echo ""
    echo "$(bold 'Installing all available plugin skills…')"
    echo ""
    installed=0
    skipped=0
    while IFS=: read -r name path; do
      if is_installed "${name}"; then
        skipped=$((skipped + 1))
      else
        install_skill "${name}" "${path}"
        installed=$((installed + 1))
      fi
    done < "${SKILL_INDEX}"
    echo ""
    echo "$(dim "Done — ${installed} installed, ${skipped} already present")"
    echo ""
    ;;

  --from-match)
    url="${2:-}"
    if [[ -z "${url}" ]]; then
      echo "Usage: install-skills --from-match <github-url>" >&2
      exit 1
    fi
    echo ""
    echo "$(bold "Running skill-inventory match ${url}…")"
    echo ""

    # Capture match output, strip ANSI, extract ↓ skill names
    # skill-inventory exits non-zero when there are items to install — that's expected
    recommended=$(skill-inventory match "${url}" 2>&1 \
      | sed 's/\x1b\[[0-9;]*m//g' \
      | grep -E '^\s+↓' \
      | awk '$2 ~ /^[a-zA-Z]/ {print $2}' || true)

    if [[ -z "${recommended}" ]]; then
      echo "  $(yellow '~') No installable skills found in match output."
      echo ""
      exit 0
    fi

    echo "$(bold 'Installing recommended skills…')"
    echo ""
    installed=0
    skipped=0
    while IFS= read -r name; do
      [[ -z "${name}" ]] && continue
      path=$(find_in_index "${name}")
      if [[ -n "${path}" ]]; then
        if is_installed "${name}"; then
          echo "  $(yellow '~') ${name} — already installed, skipping"
          skipped=$((skipped + 1))
        else
          install_skill "${name}" "${path}"
          installed=$((installed + 1))
        fi
      else
        echo "  $(yellow '?') ${name} — not found in plugin cache"
      fi
    done <<< "${recommended}"

    echo ""
    echo "$(dim "Done — ${installed} installed, ${skipped} already present")"
    echo ""
    ;;

  --help|-h)
    echo ""
    echo "$(bold 'install-skills') — copy plugin skills to ~/.claude/skills/"
    echo ""
    echo "Usage:"
    echo "  install-skills                              interactive install"
    echo "  install-skills skill1 skill2 ...            install specific skills"
    echo "  install-skills --all                        install all available"
    echo "  install-skills --list                       list available (dry run)"
    echo "  install-skills --from-match <github-url>    install match recommendations"
    echo ""
    ;;

  -*)
    echo "Unknown option: ${mode}" >&2
    echo "Run 'install-skills --help' for usage." >&2
    exit 1
    ;;

  *)
    # Specific skill names passed as arguments
    echo ""
    echo "$(bold 'Installing requested skills…')"
    echo ""
    for requested in "$@"; do
      path=$(find_in_index "${requested}")
      if [[ -n "${path}" ]]; then
        install_skill "${requested}" "${path}"
      else
        echo "  $(yellow '?') ${requested} — not found in plugin cache"
      fi
    done
    echo ""
    ;;

esac
